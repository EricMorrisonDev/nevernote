
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  notes        Note[]
  notebooks    Notebook[]

  @@map("users")
}

model Notebook {
  id        String   @id @default(uuid())
  title     String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  notes     Note[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  // optional: prevent duplicate notebook titles per user
  // @@unique([userId, title])
}

model Note {
  id          String   @id @default(uuid())
  title       String
  content     String   // markdown
  notebookId  String
  notebook    Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([notebookId])
  @@index([userId])
  // optional: speed up search by title
  // @@index([userId, title])
}